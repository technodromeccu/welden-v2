AUTH_SECRET=change-this-in-production
CRON_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
USE_BLOBS=false

# ── Firebase (Phase 1 data backend) ───────────────────────────────────────────
# Storage backend selector. "file" = current JSON/disk behavior (default).
# "firestore" activates the Firestore + Cloud Storage backend (once the adapter ships).
DATA_BACKEND=file
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
# Provide the Admin SDK credentials ONE of two ways:
#  (local)  GOOGLE_APPLICATION_CREDENTIALS=./.secrets/<service-account>.json
#  (hosted) FIREBASE_SERVICE_ACCOUNT_JSON=<full service-account JSON as one line>
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=

GEMINI_API_KEY=
# Advisor chatbot model. Defaults to gemini-3.5-flash if unset.
GEMINI_MODEL=gemini-3.5-flash
# Sampling temperature. Google recommends 1.0 for Gemini 3.x (default).
# Lower (e.g. 0.3) is more deterministic for grounded RAG but may degrade reasoning.
GEMINI_TEMPERATURE=1.0
# Reasoning depth: minimal | low | medium | high. "low" cuts advisor latency + cost
# (Gemini 3.x defaults to high). Defaults to low if unset/invalid.
GEMINI_THINKING_LEVEL=low

RESEND_API_KEY=
RESEND_SENDER_EMAIL=
RESEND_SENDER_NAME=Welden Industries
RESEND_REPLY_TO_EMAIL=

NETLIFY_SITE_URL=

GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
BACKUP_CRON_SECRET=
BACKUP_ENCRYPTION_KEY=
BACKUP_ALERT_EMAILS=
